{
  "openapi": "3.1.0",
  "info": {
    "title": "flaps HTTP API",
    "version": "0.1.0",
    "description": "Admin CRUD, SDK key management, SDK identity, OFREP evaluation and ruleset sync surface exposed by flaps-server. Generated by hand from build_router in crates/flaps-server/src/lib.rs (main@2715601); see docs/spec/api-v1.md for the accompanying guide (authentication model, SSE contract, ETag semantics, error format)."
  },
  "components": {
    "securitySchemes": {
      "adminSession": {
        "type": "http",
        "scheme": "bearer",
        "description": "Session bearer token minted by POST /login. Required by every /projects/** admin route (project, environment, flag, segment, flag-env-config and SDK key management)."
      },
      "sdkKey": {
        "type": "http",
        "scheme": "bearer",
        "description": "SDK key bearer token. GET /sdk/whoami and the OFREP evaluation routes accept both server-kind and client-kind keys. The /sync/v1/* routes require a server-kind key; a client-kind key on those routes receives 403 Forbidden (see api-v1.md for the server-vs-client distinction, which this single security scheme does not model)."
      }
    },
    "parameters": {
      "ProjectParam": {
        "name": "project",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "Project key (kebab-case)."
      },
      "EnvParam": {
        "name": "env",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "Environment key (kebab-case)."
      },
      "FlagParam": {
        "name": "flag",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "Flag key (kebab-case)."
      },
      "SegmentParam": {
        "name": "segment",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "Segment key (kebab-case)."
      },
      "PrefixParam": {
        "name": "prefix",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "Readable prefix of the SDK key to revoke (the leading characters of the raw key, as returned in SdkKeyRecord.prefix)."
      },
      "OfrepFlagKeyParam": {
        "name": "key",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "Flag key to evaluate."
      },
      "IfMatchHeader": {
        "name": "If-Match",
        "in": "header",
        "required": false,
        "schema": { "type": "string" },
        "description": "Optional strong ETag precondition for optimistic concurrency control. When present and different from the current ETag, the request fails with 412 Precondition Failed and no write occurs."
      },
      "IfNoneMatchHeader": {
        "name": "If-None-Match",
        "in": "header",
        "required": false,
        "schema": { "type": "string" },
        "description": "Optional ETag for conditional GET. An exact match short-circuits to 304 Not Modified with no body."
      }
    },
    "headers": {
      "ETagHeader": {
        "description": "Strong ETag: hex SHA-256 of the canonical (key-sorted) JSON serialization of the resource.",
        "schema": { "type": "string" }
      },
      "XFlapsVersionHeader": {
        "description": "Monotone version counter of the compiled ruleset.",
        "schema": { "type": "integer", "format": "int64" }
      },
      "XFlapsWarningHeader": {
        "description": "Present only when the resource is federation-managed: local edits may be overwritten by the next federation sync.",
        "schema": { "type": "string" }
      },
      "RetryAfterHeader": {
        "description": "Suggested wait time in seconds before retrying, present on 429 responses.",
        "schema": { "type": "integer", "format": "int64" }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Missing or invalid authentication credentials.",
        "content": {
          "application/problem+json": { "schema": { "$ref": "#/components/schemas/Problem" } }
        }
      },
      "ForbiddenServerKeyOnly": {
        "description": "The endpoint requires a server-kind SDK key; a client-kind key was supplied.",
        "content": {
          "application/problem+json": { "schema": { "$ref": "#/components/schemas/Problem" } }
        }
      },
      "NotFound": {
        "description": "The addressed resource does not exist.",
        "content": {
          "application/problem+json": { "schema": { "$ref": "#/components/schemas/Problem" } }
        }
      },
      "InvalidBody": {
        "description": "The request body or a path key failed validation (malformed kebab-case key, or the path key does not match the body key).",
        "content": {
          "application/problem+json": { "schema": { "$ref": "#/components/schemas/Problem" } }
        }
      },
      "ValidationFailed": {
        "description": "The proposed change does not compile into a valid ruleset (e.g. a targeting rule references an unknown segment). The write is refused.",
        "content": {
          "application/problem+json": { "schema": { "$ref": "#/components/schemas/Problem" } }
        }
      },
      "PreconditionFailed": {
        "description": "The supplied If-Match header does not match the current ETag; the write was refused.",
        "content": {
          "application/problem+json": { "schema": { "$ref": "#/components/schemas/Problem" } }
        }
      },
      "Conflict": {
        "description": "A uniqueness conflict: the supplied external_ref is already used by another resource.",
        "content": {
          "application/problem+json": { "schema": { "$ref": "#/components/schemas/Problem" } }
        }
      },
      "TooManyRequests": {
        "description": "Rate limit exceeded.",
        "headers": {
          "Retry-After": { "$ref": "#/components/headers/RetryAfterHeader" }
        },
        "content": {
          "application/problem+json": { "schema": { "$ref": "#/components/schemas/Problem" } }
        }
      },
      "InternalError": {
        "description": "Unexpected internal error (e.g. a persistence failure).",
        "content": {
          "application/problem+json": { "schema": { "$ref": "#/components/schemas/Problem" } }
        }
      }
    },
    "schemas": {
      "Problem": {
        "type": "object",
        "description": "RFC 9457 problem+json error body.",
        "properties": {
          "type": { "type": "string", "format": "uri", "description": "Stable problem type URI, e.g. https://flaps.dev/problems/not-found." },
          "title": { "type": "string" },
          "status": { "type": "integer" },
          "detail": { "type": "string" }
        },
        "required": ["type", "title", "status", "detail"]
      },
      "ManagedBy": {
        "type": "string",
        "enum": ["local", "federated"],
        "description": "Whether the resource is owned locally or replicated from a federation."
      },
      "FlagType": {
        "type": "string",
        "enum": ["release", "ops", "experiment", "permission"]
      },
      "ValueType": {
        "type": "string",
        "enum": ["boolean", "string", "number", "object"]
      },
      "SdkKeyKind": {
        "type": "string",
        "enum": ["server", "client"],
        "description": "server keys carry full flag data; client keys receive a filtered, client-safe subset."
      },
      "MatchOperator": {
        "type": "string",
        "enum": [
          "equals", "not_equals", "in", "not_in",
          "starts_with", "ends_with", "contains",
          "sem_ver_eq", "sem_ver_neq", "sem_ver_lt", "sem_ver_lte",
          "sem_ver_gt", "sem_ver_gte", "sem_ver_caret", "sem_ver_tilde"
        ]
      },
      "Predicate": {
        "type": "object",
        "properties": {
          "attribute": { "type": "string" },
          "operator": { "$ref": "#/components/schemas/MatchOperator" },
          "values": { "type": "array", "items": {} }
        },
        "required": ["attribute", "operator", "values"]
      },
      "SegmentMatch": {
        "description": "A recursive boolean expression over predicates.",
        "oneOf": [
          {
            "type": "object",
            "properties": { "and": { "type": "array", "items": { "$ref": "#/components/schemas/SegmentMatch" } } },
            "required": ["and"]
          },
          {
            "type": "object",
            "properties": { "or": { "type": "array", "items": { "$ref": "#/components/schemas/SegmentMatch" } } },
            "required": ["or"]
          },
          {
            "type": "object",
            "properties": { "not": { "$ref": "#/components/schemas/SegmentMatch" } },
            "required": ["not"]
          },
          {
            "type": "object",
            "properties": { "predicate": { "$ref": "#/components/schemas/Predicate" } },
            "required": ["predicate"]
          }
        ]
      },
      "Segment": {
        "type": "object",
        "properties": {
          "key": { "type": "string" },
          "name": { "type": "string" },
          "match_expr": { "$ref": "#/components/schemas/SegmentMatch" }
        },
        "required": ["key", "name", "match_expr"]
      },
      "VariantValue": {
        "description": "A concrete value carried by a variant; the active arm must match the flag's value_type.",
        "oneOf": [
          { "type": "object", "properties": { "bool": { "type": "boolean" } }, "required": ["bool"] },
          { "type": "object", "properties": { "string": { "type": "string" } }, "required": ["string"] },
          { "type": "object", "properties": { "number": { "type": "number" } }, "required": ["number"] },
          { "type": "object", "properties": { "json": {} }, "required": ["json"] }
        ]
      },
      "Variants": {
        "type": "object",
        "description": "The validated set of variants declared globally on a flag; every value type matches value_type.",
        "properties": {
          "value_type": { "$ref": "#/components/schemas/ValueType" },
          "entries": {
            "type": "object",
            "additionalProperties": { "$ref": "#/components/schemas/VariantValue" },
            "description": "Map keyed by variant key."
          }
        },
        "required": ["value_type", "entries"]
      },
      "Flag": {
        "type": "object",
        "properties": {
          "key": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": ["string", "null"] },
          "flag_type": { "$ref": "#/components/schemas/FlagType" },
          "value_type": { "$ref": "#/components/schemas/ValueType" },
          "variants": { "$ref": "#/components/schemas/Variants" }
        },
        "required": ["key", "name", "description", "flag_type", "value_type", "variants"]
      },
      "WeightedVariant": {
        "type": "object",
        "properties": {
          "variant": { "type": "string" },
          "weight": { "type": "integer", "minimum": 0 }
        },
        "required": ["variant", "weight"]
      },
      "ServeTarget": {
        "description": "Determines which variant to serve when a rule matches.",
        "oneOf": [
          {
            "type": "object",
            "properties": { "fixed": { "type": "string", "description": "Variant key always served." } },
            "required": ["fixed"]
          },
          {
            "type": "object",
            "properties": {
              "rollout": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/WeightedVariant" },
                "description": "Weighted variants; the total weight is validated to be strictly positive."
              }
            },
            "required": ["rollout"]
          }
        ]
      },
      "TargetingRule": {
        "type": "object",
        "properties": {
          "segments": { "type": "array", "items": { "type": "string" }, "description": "All listed segments must match for this rule to fire." },
          "serve": { "$ref": "#/components/schemas/ServeTarget" }
        },
        "required": ["segments", "serve"]
      },
      "FlagEnvConfig": {
        "type": "object",
        "description": "Per-environment flag configuration. Rules are evaluated in order; the first match wins, default_rule otherwise.",
        "properties": {
          "enabled": { "type": "boolean" },
          "rules": { "type": "array", "items": { "$ref": "#/components/schemas/TargetingRule" } },
          "default_rule": { "$ref": "#/components/schemas/ServeTarget" }
        },
        "required": ["enabled", "rules", "default_rule"]
      },
      "Project": {
        "type": "object",
        "properties": {
          "key": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": ["string", "null"] },
          "external_ref": { "type": ["string", "null"], "description": "Opaque reference to the project in a federated system." },
          "managed_by": { "$ref": "#/components/schemas/ManagedBy" }
        },
        "required": ["key", "name", "description", "external_ref", "managed_by"]
      },
      "Environment": {
        "type": "object",
        "properties": {
          "key": { "type": "string" },
          "name": { "type": "string" },
          "external_ref": { "type": ["string", "null"] },
          "managed_by": { "$ref": "#/components/schemas/ManagedBy" }
        },
        "required": ["key", "name", "external_ref", "managed_by"]
      },
      "SdkKeyScope": {
        "type": "object",
        "properties": {
          "project_key": { "type": "string" },
          "environment_key": { "type": "string" }
        },
        "required": ["project_key", "environment_key"]
      },
      "SdkKeyRecord": {
        "type": "object",
        "description": "Persisted, secret-free view of an SDK key: never carries the raw value or its hash.",
        "properties": {
          "prefix": { "type": "string" },
          "kind": { "$ref": "#/components/schemas/SdkKeyKind" },
          "scope": { "$ref": "#/components/schemas/SdkKeyScope" },
          "created_at": { "type": "string", "format": "date-time" },
          "revoked_at": { "type": ["string", "null"], "format": "date-time" }
        },
        "required": ["prefix", "kind", "scope", "created_at", "revoked_at"]
      },
      "CreateSdkKeyRequest": {
        "type": "object",
        "properties": {
          "kind": { "$ref": "#/components/schemas/SdkKeyKind" }
        },
        "required": ["kind"]
      },
      "CreateSdkKeyResponse": {
        "type": "object",
        "description": "Only returned on creation: the raw secret is never exposed again afterwards.",
        "properties": {
          "secret": { "type": "string" },
          "record": { "$ref": "#/components/schemas/SdkKeyRecord" }
        },
        "required": ["secret", "record"]
      },
      "WhoamiResponse": {
        "type": "object",
        "properties": {
          "scope": { "$ref": "#/components/schemas/SdkKeyScope" },
          "kind": { "$ref": "#/components/schemas/SdkKeyKind" }
        },
        "required": ["scope", "kind"]
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "username": { "type": "string" },
          "password": { "type": "string" }
        },
        "required": ["username", "password"]
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "token": { "type": "string", "description": "Opaque bearer token for subsequent Authorization: Bearer headers." },
          "expires_at": { "type": "string", "format": "date-time" }
        },
        "required": ["token", "expires_at"]
      },
      "OfrRepReason": {
        "type": "string",
        "enum": ["STATIC", "TARGETING_MATCH", "DEFAULT", "DISABLED"]
      },
      "OfrRepErrorCode": {
        "type": "string",
        "enum": ["FLAG_NOT_FOUND", "INVALID_CONTEXT", "GENERAL"]
      },
      "EvaluationContext": {
        "type": "object",
        "description": "OFREP evaluation context: targetingKey plus arbitrary flattened attributes.",
        "properties": {
          "targetingKey": { "type": "string" }
        },
        "additionalProperties": true
      },
      "EvaluationRequest": {
        "type": "object",
        "description": "Shared request body for both OFREP evaluation endpoints.",
        "properties": {
          "context": { "$ref": "#/components/schemas/EvaluationContext" }
        }
      },
      "SingleSuccessResponse": {
        "type": "object",
        "properties": {
          "key": { "type": "string" },
          "value": { "description": "Omitted when the flag is disabled." },
          "reason": { "$ref": "#/components/schemas/OfrRepReason" },
          "variant": { "type": "string", "description": "Omitted when no variant was resolved." }
        },
        "required": ["key", "reason"]
      },
      "SingleErrorResponse": {
        "type": "object",
        "properties": {
          "key": { "type": "string" },
          "errorCode": { "$ref": "#/components/schemas/OfrRepErrorCode" },
          "errorDetails": { "type": "string" }
        },
        "required": ["key", "errorCode", "errorDetails"]
      },
      "BulkFlagEntry": {
        "description": "One entry in the bulk flags array: either a success or a per-flag error.",
        "oneOf": [
          { "$ref": "#/components/schemas/SingleSuccessResponse" },
          { "$ref": "#/components/schemas/SingleErrorResponse" }
        ]
      },
      "BulkMetadata": {
        "type": "object",
        "properties": {
          "version": { "type": "string", "description": "Monotone ruleset version, as a string per OFREP convention." }
        },
        "required": ["version"]
      },
      "BulkSuccessResponse": {
        "type": "object",
        "properties": {
          "flags": { "type": "array", "items": { "$ref": "#/components/schemas/BulkFlagEntry" } },
          "metadata": { "$ref": "#/components/schemas/BulkMetadata" }
        },
        "required": ["flags", "metadata"]
      },
      "EvaluationFailureResponse": {
        "type": "object",
        "properties": {
          "errorCode": { "$ref": "#/components/schemas/OfrRepErrorCode" },
          "errorDetails": { "type": "string" }
        },
        "required": ["errorCode", "errorDetails"]
      },
      "RulesetDocument": {
        "type": "object",
        "description": "The compiled flagd-compatible ruleset document produced by flaps-compiler. Its internal schema is opaque here; it is generated, not hand-authored, and out of scope for this contract.",
        "additionalProperties": true
      },
      "EventPayload": {
        "type": "object",
        "description": "SSE frame payload on GET /sync/v1/events. Intentionally minimal: never carries flag data, only the notification that a new version exists.",
        "properties": {
          "environment": { "type": "string" },
          "version": { "type": "integer", "format": "int64" }
        },
        "required": ["environment", "version"]
      }
    }
  },
  "paths": {
    "/login": {
      "post": {
        "summary": "Verify credentials and mint a session token",
        "operationId": "postLogin",
        "security": [],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LoginRequest" } } }
        },
        "responses": {
          "200": {
            "description": "Session token minted.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LoginResponse" } } }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/TooManyRequests" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/projects": {
      "get": {
        "summary": "List all projects",
        "operationId": "listProjects",
        "security": [{ "adminSession": [] }],
        "responses": {
          "200": {
            "description": "All projects.",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Project" } } } }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/projects/{project}": {
      "get": {
        "summary": "Fetch a single project",
        "operationId": "getProject",
        "security": [{ "adminSession": [] }],
        "parameters": [{ "$ref": "#/components/parameters/ProjectParam" }],
        "responses": {
          "200": {
            "description": "The project.",
            "headers": { "ETag": { "$ref": "#/components/headers/ETagHeader" } },
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Project" } } }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "422": { "$ref": "#/components/responses/InvalidBody" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      },
      "put": {
        "summary": "Upsert a project (idempotent)",
        "operationId": "putProject",
        "security": [{ "adminSession": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/ProjectParam" },
          { "$ref": "#/components/parameters/IfMatchHeader" }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Project" } } }
        },
        "responses": {
          "200": {
            "description": "Project updated.",
            "headers": {
              "ETag": { "$ref": "#/components/headers/ETagHeader" },
              "X-Flaps-Warning": { "$ref": "#/components/headers/XFlapsWarningHeader" }
            },
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Project" } } }
          },
          "201": {
            "description": "Project created.",
            "headers": {
              "ETag": { "$ref": "#/components/headers/ETagHeader" },
              "X-Flaps-Warning": { "$ref": "#/components/headers/XFlapsWarningHeader" }
            },
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Project" } } }
          },
          "400": { "$ref": "#/components/responses/ValidationFailed" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "412": { "$ref": "#/components/responses/PreconditionFailed" },
          "422": { "$ref": "#/components/responses/InvalidBody" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      },
      "delete": {
        "summary": "Delete a project (cascades to all child entities)",
        "operationId": "deleteProject",
        "security": [{ "adminSession": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/ProjectParam" },
          { "$ref": "#/components/parameters/IfMatchHeader" }
        ],
        "responses": {
          "204": { "description": "Project deleted." },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "412": { "$ref": "#/components/responses/PreconditionFailed" },
          "422": { "$ref": "#/components/responses/InvalidBody" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/projects/{project}/environments": {
      "get": {
        "summary": "List environments in a project",
        "operationId": "listEnvironments",
        "security": [{ "adminSession": [] }],
        "parameters": [{ "$ref": "#/components/parameters/ProjectParam" }],
        "responses": {
          "200": {
            "description": "All environments in the project.",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Environment" } } } }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "422": { "$ref": "#/components/responses/InvalidBody" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/projects/{project}/environments/{env}": {
      "get": {
        "summary": "Fetch a single environment",
        "operationId": "getEnvironment",
        "security": [{ "adminSession": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/ProjectParam" },
          { "$ref": "#/components/parameters/EnvParam" }
        ],
        "responses": {
          "200": {
            "description": "The environment.",
            "headers": { "ETag": { "$ref": "#/components/headers/ETagHeader" } },
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Environment" } } }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "422": { "$ref": "#/components/responses/InvalidBody" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      },
      "put": {
        "summary": "Upsert an environment",
        "operationId": "putEnvironment",
        "security": [{ "adminSession": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/ProjectParam" },
          { "$ref": "#/components/parameters/EnvParam" },
          { "$ref": "#/components/parameters/IfMatchHeader" }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Environment" } } }
        },
        "responses": {
          "200": {
            "description": "Environment updated.",
            "headers": {
              "ETag": { "$ref": "#/components/headers/ETagHeader" },
              "X-Flaps-Warning": { "$ref": "#/components/headers/XFlapsWarningHeader" }
            },
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Environment" } } }
          },
          "201": {
            "description": "Environment created.",
            "headers": {
